---
interface Props {
  id: string
  quote: string
  author?: string
  class?: string
  style?: string
}

const { id, quote, author, class: className = '', style = '' } = Astro.props
---

<span
  class:list={['tb-wisdom-gem', className]}
  data-wisdom-id={id}
  data-quote={quote}
  data-author={author || ''}
  style={style}
  role="button"
  tabindex="0"
  aria-label="A wisdom gem glimmers here. Click to receive its message."
>
  <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M10 2 L16 8 L10 18 L4 8 Z" fill="currentColor" />
    <path d="M4 8 L16 8 M10 2 L10 18" stroke="currentColor" stroke-width="0.5" opacity="0.3" />
  </svg>
</span>
