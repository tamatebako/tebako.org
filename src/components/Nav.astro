---
import Logo from './Logo.astro'
import DarkToggle from './DarkToggle.vue'
import MobileMenu from './MobileMenu.vue'
import SearchButton from './SearchButton.vue'
import { NAV_ITEMS } from '../config/site'

const pathname = Astro.url.pathname
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href)
---

<header class="fixed inset-x-0 top-0 z-50">
  <div
    class="border-b border-[var(--tb-c-divider)] backdrop-blur-xl"
    style="background: var(--tb-c-nav-bg); box-shadow: 0 1px 0 var(--tb-c-divider), 0 4px 24px -8px rgba(6, 57, 74, 0.08);"
  >
    <nav class="mx-auto flex h-16 max-w-7xl items-center gap-6 px-6">
      <Logo />

      <div class="ml-6 hidden items-center gap-1 md:flex">
        {NAV_ITEMS.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-full px-4 py-2 text-sm font-medium transition-colors duration-200',
              isActive(item.href)
                ? 'bg-[var(--tb-c-accent)] text-[var(--color-paper)]'
                : 'text-[var(--tb-c-text-2)] hover:text-[var(--tb-c-text-1)] hover:bg-[var(--tb-c-divider)]',
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>

      <div class="ml-auto flex items-center gap-2">
        <SearchButton client:idle />
        <DarkToggle client:load />
        <MobileMenu client:load nav={NAV_ITEMS} class="md:hidden" />
      </div>
    </nav>
  </div>
</header>
