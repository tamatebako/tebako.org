---
import type { CollectionEntry } from 'astro:content'
import { formatDateShort } from '../lib/format-date'

interface Props {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props
const date = formatDateShort(post.data.date)
const primaryAuthor = post.data.author[0]
const href = `/blog/${post.id}/`
---

<article class="tb-card group p-8">
  <div class="mb-3 flex flex-wrap items-center gap-3 font-[var(--font-mono)] text-xs text-[var(--tb-c-text-3)]">
    <time datetime={post.data.date.toISOString()}>{date}</time>
    {post.data.categories.map((cat) => (
      <span class="rounded-full bg-[var(--tb-c-divider)] px-2.5 py-0.5">{cat}</span>
    ))}
  </div>

  <h2 class="font-[var(--font-display)] text-2xl font-medium leading-snug">
    <a
      href={href}
      class="text-[var(--tb-c-text-1)] transition-colors group-hover:text-[var(--tb-c-accent)]"
    >
      {post.data.title}
    </a>
  </h2>

  {post.data.excerpt && (
    <p class="mt-3 leading-relaxed text-[var(--tb-c-text-2)]">{post.data.excerpt}</p>
  )}

  {primaryAuthor && (
    <div class="mt-5 flex items-center gap-2 text-sm text-[var(--tb-c-text-3)]">
      <span>{primaryAuthor.name}</span>
      <span aria-hidden="true">·</span>
      <a
        href={href}
        class="font-medium text-[var(--tb-c-accent)] opacity-0 transition-opacity group-hover:opacity-100"
      >
        Read more →
      </a>
    </div>
  )}
</article>
