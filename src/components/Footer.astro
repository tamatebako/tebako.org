---
import { SITE, FOOTER_LINKS } from '../config/site'
import HiddenGem from './HiddenGem.astro'
import WisdomGem from './WisdomGem.astro'
const year = new Date().getFullYear()
---

<footer class="mt-32 border-t border-[var(--tb-c-divider)]">
  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-12 md:grid-cols-[2fr_1fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-2.5">
          <span class="block h-8 w-8 text-[var(--tb-c-accent)]">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M6 26 L6 44 L42 44 L42 26" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linejoin="round" stroke-linecap="round" />
              <path d="M6 26 L12 20 L36 20 L42 26" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linejoin="round" stroke-linecap="round" opacity="0.5" />
              <path d="M24 4 L36 16 L24 30 L12 16 Z" fill="currentColor" />
            </svg>
          </span>
          <span class="font-[var(--font-display)] text-lg font-medium">tebako</span>
        </div>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-[var(--tb-c-text-2)]">
          {SITE.description}
        </p>
        <p class="mt-4 font-[var(--font-mono)] text-xs text-[var(--tb-c-text-3)]">
          玉手箱 — the jewel box for Ruby
          <HiddenGem id="footer-treasure" style="display:inline-block; margin-left:0.25rem; vertical-align:middle; opacity:0.05;" />
          <WisdomGem id="footer-wisdom" quote="Like Urashima, we carry the box. Unlike Urashima, we choose when to open it." style="display:inline-block; margin-left:0.25rem; vertical-align:middle;" />
        </p>
      </div>

      {Object.entries(FOOTER_LINKS).map(([heading, links]) => (
        <nav aria-label={heading}>
          <h2 class="font-[var(--font-mono)] text-xs font-medium uppercase tracking-widest text-[var(--tb-c-text-3)]">
            {heading}
          </h2>
          <ul class="mt-4 space-y-3">
            {links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-[var(--tb-c-text-2)] transition-colors hover:text-[var(--tb-c-accent)]"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-[var(--tb-c-divider)] pt-8 sm:flex-row">
      <p class="text-sm text-[var(--tb-c-text-3)]">
        &copy; {year} {SITE.legal.name}. Open source under the BSD-2-Clause license.
      </p>
      <div class="flex items-center gap-4">
        <a
          href={SITE.github}
          class="text-[var(--tb-c-text-2)] transition-colors hover:text-[var(--tb-c-accent)]"
          aria-label="GitHub"
        >
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
