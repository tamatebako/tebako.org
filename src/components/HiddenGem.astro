---
interface Props {
  id: string
  class?: string
  style?: string
}

const { id, class: className = '', style = '' } = Astro.props
---

<span
  class:list={['tb-hidden-gem', className]}
  data-gem-id={id}
  style={style}
  role="button"
  tabindex="0"
  aria-label="A hidden gem glimmers here. Click to collect."
  title="✨"
>
  <svg viewBox="0 0 16 16" aria-hidden="true">
    <path d="M8 1 L13 6 L8 15 L3 6 Z" fill="currentColor" />
    <path d="M3 6 L13 6" stroke="currentColor" stroke-width="0.5" opacity="0.4" />
    <path d="M8 1 L8 15" stroke="currentColor" stroke-width="0.5" opacity="0.2" />
  </svg>
</span>

<style>
  .tb-hidden-gem {
    display: inline-block;
    width: 14px;
    height: 14px;
    color: var(--tb-c-accent);
    opacity: 0.05;
    cursor: pointer;
    pointer-events: auto;
    transition: opacity 0.4s var(--ease-out-quint, ease), transform 0.4s var(--ease-out-quint, ease);
    vertical-align: middle;
    position: relative;
    z-index: 1;
  }
  .tb-hidden-gem:hover,
  .tb-hidden-gem:focus-visible {
    opacity: 0.9;
    transform: scale(1.6) rotate(180deg);
    outline: none;
  }
  .tb-hidden-gem.found {
    opacity: 0 !important;
    pointer-events: none;
    transform: scale(0);
  }
  .tb-hidden-gem svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 0 4px rgba(248, 184, 131, 0.5));
  }
</style>
